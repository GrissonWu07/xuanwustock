# ============================================================
# AI股票分析系统环境配置模板
# ============================================================
# 使用说明：
# 1. 复制此文件并重命名为 .env
# 2. 根据实际情况填写配置项
# 3. 敏感信息（如API密钥、密码）请妥善保管，不要提交到版本控制
# ============================================================

# ========== AI API配置 ==========
# AI API密钥（必填）
# 获取地址：OpenRouter 控制台获取 API Key
DEEPSEEK_API_KEY=your_openrouter_api_key_here

# AI API地址（可选）
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# 默认模型（可选，建议使用 OpenRouter 完整模型ID）
DEFAULT_MODEL_NAME=deepseek/deepseek-v3.2


# ========== Tushare数据接口（可选）==========
# Tushare Token（可选，用于获取更多金融数据）
# 获取地址：https://tushare.pro/register
TUSHARE_TOKEN=


# ========== MiniQMT量化交易配置（可选）==========
# 是否启用MiniQMT量化交易接口
MINIQMT_ENABLED=false

# MiniQMT账户ID
MINIQMT_ACCOUNT_ID=

# MiniQMT服务器地址
MINIQMT_HOST=127.0.0.1

# MiniQMT服务器端口
MINIQMT_PORT=58610


# ========== 邮件通知配置（可选）==========
# 是否启用邮件通知
EMAIL_ENABLED=false

# SMTP服务器地址
# 常用邮箱SMTP服务器：
#   - 163邮箱：smtp.163.com
#   - QQ邮箱：smtp.qq.com
#   - Gmail：smtp.gmail.com
#   - 企业邮箱：根据邮箱服务商提供的信息填写
SMTP_SERVER=smtp.163.com

# SMTP服务器端口
# 常用端口：
#   - 465：SSL加密连接163邮箱常用（推荐）
#   - 587：TLS加密连接
SMTP_PORT=465

# 发件人邮箱地址
EMAIL_FROM=your_email@163.com

# 邮箱授权码（不是登录密码！）
# 获取方法：
#   - 163邮箱：设置 -> POP3/SMTP/IMAP -> 开启服务 -> 获取授权码
#   - QQ邮箱：设置 -> 账户 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务 -> 开启服务 -> 生成授权码
EMAIL_PASSWORD=your_email_authorization_code

# 收件人邮箱地址（接收通知的邮箱）
EMAIL_TO=receiver@example.com


# ========== Webhook通知配置（可选）==========
# 是否启用Webhook通知（钉钉/飞书）
WEBHOOK_ENABLED=false

# Webhook类型
# 可选值：dingtalk（钉钉）、feishu（飞书）
WEBHOOK_TYPE=dingtalk

# Webhook地址
# 钉钉机器人：https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN
# 飞书机器人：https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
WEBHOOK_URL=

# Webhook自定义关键词（仅钉钉需要）
# 说明：
#   - 如果钉钉机器人设置了"自定义关键词"安全验证，请在此填写关键词
#   - 系统会自动在消息标题和内容中包含此关键词
#   - 如果不使用关键词验证，可以留空或使用其他安全方式（加签、IP白名单）
#   - 飞书机器人通常不需要关键词，可以留空
# 示例：aiagents通知
WEBHOOK_KEYWORD=


# ========== 时区配置 ==========
# 系统时区设置（可选）
TZ=Asia/Shanghai

# ========== 本地行情数据源 ==========
# 技术指标/K线优先读取本地 parquet，缺口或过期时再访问 AKShare、Tushare、TDX。
MARKET_DATA_CACHE_ENABLED=true
LOCAL_MARKET_DATA_DIR=data/local_sources
MARKET_DATA_PARQUET_ENGINE=pyarrow


# ========== TDX数据源配置（pytdx 直连，可选）==========
# 说明：
#   - 启用后，项目会通过 pytdx 直连通达信行情服务器
#   - 如果未配置 TDX_HOST，则默认使用 pytdx 内置服务器列表
#   - 如需显式指定主服务器，可填写 TDX_HOST + TDX_PORT
#   - TDX_FALLBACK_HOSTS 支持逗号分隔的 host:port 列表
TDX_ENABLED=false
TDX_HOST=
TDX_PORT=7709
TDX_TIMEOUT=5
TDX_FALLBACK_HOSTS=119.147.212.81:7709,119.147.212.83:7709


# ========== 低价擒牛策略监控配置 ==========
# 扫描间隔（秒）
# 说明：
#   - 监控服务扫描股票的时间间隔
#   - 建议范围：30-300秒
#   - 默认值：60秒（每分钟扫描1次）
LOW_PRICE_BULL_SCAN_INTERVAL=60

# 持股天数限制
# 说明：
#   - 持股达到该天数后自动提醒卖出
#   - 按自然日计算，不区分交易日
#   - 默认值：5天
LOW_PRICE_BULL_HOLDING_DAYS=5
